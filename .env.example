# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# YouTube OAuth（ローカルでreauth後に生成されるtoken.jsonの内容をそのままJSON文字列で）
# GitHub Actions では Secrets に登録する
YOUTUBE_OAUTH_TOKEN_JSON={"access_token":"...","refresh_token":"...","scope":"...","token_type":"Bearer","expiry_date":0}

# YouTube OAuth クライアント情報
YOUTUBE_CLIENT_ID=your-client-id
YOUTUBE_CLIENT_SECRET=your-client-secret
